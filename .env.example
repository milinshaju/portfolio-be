PORT=4000
NODE_ENV=development

# MongoDB — local default, replace with Atlas URI in prod
MONGODB_URI=mongodb://localhost:27017/milin-platform

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# G30 admin auth — REPLACE in prod
JWT_SECRET=your-random-long-secret-here
JWT_EXPIRES_IN=7d

# Seeded super-admin credentials (used by `npm run seed:superadmin`)
SUPERADMIN_EMAIL=super@g30sportsclub.example
SUPERADMIN_PASSWORD=changeme-1234
SUPERADMIN_NAME=Super Admin

# Tournament super-admin (separate account — not connected to G30)
TOURNAMENT_SUPERADMIN_EMAIL=super@badminton-tournament.example
TOURNAMENT_SUPERADMIN_PASSWORD=changeme-1234
TOURNAMENT_SUPERADMIN_NAME=Tournament Admin
